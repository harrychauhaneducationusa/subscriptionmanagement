PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Optional shared secret: required in production for `GET /v1/internal/launch-readiness` (see `x-internal-ops-token`).
# When unset in development, that route is allowed for any authenticated session (dogfood only).
INTERNAL_OPS_TOKEN=
DATABASE_URL=postgres://postgres:postgres@localhost:5432/subsense
DATABASE_POOL_MAX=10
REDIS_URL=redis://localhost:6379
# Required in production for `POST /v1/aggregation/callbacks/setu` (Setu-style provider callbacks).
# Send as `X-Subsense-Callback-Secret` or `Authorization: Bearer <secret>`.
AGGREGATION_CALLBACK_SECRET=
# Bank link provider: `mock` | `setu` (India) | `plaid` (US, planned on feature/plaid-integration).
# Only one active provider per deployment; India prod should use `setu`, US POC/prod uses `plaid`.
# See docs/architecture/multi-market-aggregation.md
AGGREGATION_PROVIDER=mock
# Required when AGGREGATION_PROVIDER=setu. Run: npm run setup:setu (after Bridge Step 2 credentials).
SETU_AA_BASE_URL=https://fiu-sandbox.setu.co
SETU_AA_CREATE_CONSENT_PATH=/v2/consent
SETU_AA_TOKEN_URL=https://uat.setu.co/api/v2/auth/token
SETU_AA_CLIENT_ID=
SETU_AA_CLIENT_SECRET=
SETU_AA_PRODUCT_INSTANCE_ID=
SETU_AA_API_KEY=
SETU_AA_AUTH_HEADER=Authorization
SETU_AA_CUSTOMER_VUA=9999999999@setu
SETU_AA_CUSTOMER_MOBILE=9999999999
SETU_AA_FIU_ID=subsense-fiu-placeholder
SETU_AA_SCHEMA_VERSION=2.1.0
# Placeholders: {{handle}} = ConsentHandle (URL-encoded), {{returnUrl}} = URL-encoded app return path.
SETU_AA_WEB_REDIRECT_TEMPLATE=https://bridge.setu.co/aa/consent?consentHandle={{handle}}&redirect={{returnUrl}}

# --- Plaid (US market) — not required for India / Setu deployments ---
# Run: npm run setup:plaid (keys from https://dashboard.plaid.com/developers/keys)
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox
# PLAID_PRODUCTS=transactions
# PLAID_COUNTRY_CODES=US
# Optional OAuth redirect — must match Plaid Dashboard → Allowed redirect URIs. Omit for default sandbox Link.
# PLAID_OAUTH_REDIRECT_URI=http://localhost:5173/app/bank-link

# Allow `POST /v1/aggregation/consents/:id/mock-callback` when NODE_ENV=production (e.g. staging demos).
ENABLE_AGGREGATION_SESSION_MOCK=false
OTP_TEST_CODE=123456
VITE_API_BASE_URL=http://localhost:4000
# Match API AGGREGATION_PROVIDER for Bank Link UI (mock | setu | plaid)
VITE_AGGREGATION_PROVIDER=mock
# Optional: show the Ops nav link in production builds (defaults off except in Vite dev).
VITE_SHOW_OPS_NAV=false
# Must match API `INTERNAL_OPS_TOKEN` when that env is set (sent as `x-internal-ops-token`).
VITE_INTERNAL_OPS_TOKEN=
# Show “Continue with Google” on the session page (must match API Google OAuth being enabled).
VITE_ENABLE_GOOGLE_OAUTH=false
NOTIFICATION_EMAIL_MODE=mock
# Use `smtp` with SMTP_HOST / SMTP_USER / SMTP_PASS to send real notification emails.
NOTIFICATION_EMAIL_FROM=hello@subsense.local
NOTIFICATION_EMAIL_TEST_RECIPIENT=sandbox@subsense.local

# --- Email OTP (API) ---
ENABLE_EMAIL_OTP=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_FROM_NAME=SubSense
OTP_EMAIL_PEPPER=
EMAIL_OTP_EXPIRY_MINUTES=15

# --- Google OAuth (API) ---
ENABLE_GOOGLE_OAUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match an authorized redirect URI in Google Cloud Console, e.g.:
# GOOGLE_CALLBACK_URL=http://localhost:4000/v1/auth/google/callback
GOOGLE_CALLBACK_URL=
