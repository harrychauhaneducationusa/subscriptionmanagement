PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Optional shared secret: required in production for `GET /v1/internal/launch-readiness` (see `x-internal-ops-token`).
# When unset in development, that route is allowed for any authenticated session (dogfood only).
INTERNAL_OPS_TOKEN=
DATABASE_URL=postgres://postgres:postgres@localhost:5432/subsense
DATABASE_POOL_MAX=10
REDIS_URL=redis://localhost:6379
# Required in production for `POST /v1/aggregation/callbacks/setu` (Setu-style provider callbacks).
# Send as `X-Subsense-Callback-Secret` or `Authorization: Bearer <secret>`.
AGGREGATION_CALLBACK_SECRET=
# Allow `POST /v1/aggregation/consents/:id/mock-callback` when NODE_ENV=production (e.g. staging demos).
ENABLE_AGGREGATION_SESSION_MOCK=false
OTP_TEST_CODE=123456
VITE_API_BASE_URL=http://localhost:4000
# Optional: show the Ops nav link in production builds (defaults off except in Vite dev).
VITE_SHOW_OPS_NAV=false
# Must match API `INTERNAL_OPS_TOKEN` when that env is set (sent as `x-internal-ops-token`).
VITE_INTERNAL_OPS_TOKEN=
# Show “Continue with Google” on the session page (must match API Google OAuth being enabled).
VITE_ENABLE_GOOGLE_OAUTH=false
NOTIFICATION_EMAIL_MODE=mock
# Use `smtp` with SMTP_HOST / SMTP_USER / SMTP_PASS to send real notification emails.
NOTIFICATION_EMAIL_FROM=hello@subsense.local
NOTIFICATION_EMAIL_TEST_RECIPIENT=sandbox@subsense.local

# --- Email OTP (API) ---
ENABLE_EMAIL_OTP=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_FROM_NAME=SubSense
OTP_EMAIL_PEPPER=
EMAIL_OTP_EXPIRY_MINUTES=15

# --- Google OAuth (API) ---
ENABLE_GOOGLE_OAUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match an authorized redirect URI in Google Cloud Console, e.g.:
# GOOGLE_CALLBACK_URL=http://localhost:4000/v1/auth/google/callback
GOOGLE_CALLBACK_URL=
